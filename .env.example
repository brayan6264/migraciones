APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./document_engine.db
TEMP_DIR=./data/tmp

GOOGLE_AUTH_MODE=service_account
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
GOOGLE_ROOT_FOLDER_ID=
GOOGLE_SHARED_DRIVE_ID=

FTP_MODE=ftps
FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=
FTP_ROOT_PATH=/DOCUMENT_ENGINE
FTP_PASSIVE=true
FTP_VERIFY_TLS=true
FTP_TIMEOUT_SECONDS=60

OPENAI_API_KEY=
OPENAI_RENAME_ENABLED=true
OPENAI_RENAME_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_CONCURRENCY=3

TRANSFER_CHUNK_SIZE_MB=8
MAX_ITEM_RETRIES=5
RETRY_BASE_SECONDS=2
WORKER_LEASE_SECONDS=120
WORKER_HEARTBEAT_SECONDS=30
VALIDATION_LEVEL=BASIC

INTERNAL_API_KEY=
